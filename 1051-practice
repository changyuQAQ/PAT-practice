int main()
{
	int m, n, k; cin >> m >> n >> k;
	for (int i = 0; i < k; i++)
	{
		stack<int>st;
		bool f1 = false;
		int cnt = 1;
		int arr[1010];
		for (int j = 1; j <= n; j++)cin >> arr[j];
		for (int c = 1; c <= n; c++)
		{
			st.push(c);
			if (st.size() > m)break;
			while (!st.empty()&&st.top() == arr[cnt])
			{
				cnt++;
				st.pop(); 
			}
		}		
		if (st.empty() && cnt == n+1)f1 = true;
		if (f1)cout << "YES" << endl;
		else cout << "NO" << endl;
	}
}
